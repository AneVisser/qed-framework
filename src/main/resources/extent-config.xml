<?xml version="1.0" encoding="UTF-8"?>
<extentreports>
    <configuration>
        <!-- report theme -->
        <!-- standard, dark -->
        <documentTitle>Test Execution Report</documentTitle>

        <!-- document encoding -->
        <!-- defaults to UTF-8 -->
        <encoding>UTF-8</encoding>

        <!-- protocol for script and stylesheets -->
        <!-- defaults to https -->
        <protocol>http</protocol>

        <!-- title of the document -->
        <reportName>Test Execution Report
            <![CDATA[

            ]]>
        </reportName>

        <!-- report name - displayed at top-nav -->
        <scripts>
            <![CDATA[
                $(document).ready(function() {

                });
            ]]>
        </scripts>


        <!-- location of charts in the test view -->
        <!-- top, bottom -->
        <!-- Info tag white instead of blue, text same, so invisible-->
        <styles>
            <![CDATA[
            .report-name { padding-left: 18px; }
            .report-name > img { float: left;height: 90%;margin-left: 30px;margin-top: 3px;width: auto; }
            .info-bg { background-color: #FFFFFF; color: #FFFFFF; }
        ]]>
        </styles>

        <!-- custom javascript -->
        <testViewChartLocation>bottom</testViewChartLocation>

        <!-- custom styles -->
        <theme>dark</theme>
    </configuration>
</extentreports>