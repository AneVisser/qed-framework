<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--to run this suite from the command line, use:
gradlew clean test -Papichallenges
gradlew clean test - -tests "*E2E_UITestingPlayground1Test" (the hyphens should not have a space inbetween)
-->

<suite name="APIChallenges" verbose="10" parallel="methods" thread-count="4">
    <parameter name="configfile" value="src/test/kotlin/APIChallenges/apichallenges-config.json"/>
    <test name="API Test 1">
        <classes>
            <class name="APIChallenges.testcases.APIChallengesMOSHITest"/>
            <class name="APIChallenges.testcases.APIChallengesJSONTest"/>
            <class name="APIChallenges.testcases.APIChallengesGETTest"/>
            <class name="APIChallenges.testcases.APIChallengesPOSTTest"/>
            <class name="APIChallenges.testcases.APIChallengesPUTTest"/>
            <class name="APIChallenges.testcases.APIChallengesPerformanceTest"/>
        </classes>
    </test>
</suite>